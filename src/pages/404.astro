---
import Base from '../layouts/Base.astro'
---

<Base title="Page not found" description="This page could not be found.">
  <section class="nf">
    <div class="container">
      <p class="code">404</p>
      <h1>This page wandered off.</h1>
      <p class="lede">The page you were looking for is not here. Try the editions archive or head home.</p>
      <div class="actions">
        <a href="/" class="btn btn-primary">Back home</a>
        <a href="/editions" class="btn btn-ghost">Browse editions</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf {
    padding-block: clamp(4rem, 12vw, 9rem);
    text-align: center;
  }
  .code {
    font-family: var(--font-display);
    font-size: clamp(4rem, 16vw, 9rem);
    font-weight: 560;
    line-height: 1;
    color: var(--pine);
    letter-spacing: -0.03em;
  }
  .nf h1 {
    margin-top: 0.5rem;
    font-size: clamp(1.6rem, 5vw, 2.6rem);
  }
  .lede {
    margin-top: 1rem;
    margin-inline: auto;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: center;
    margin-top: 2rem;
  }
</style>

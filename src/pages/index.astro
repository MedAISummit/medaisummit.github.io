---
import Base from '../layouts/Base.astro'
import SectionHeading from '../components/SectionHeading.astro'
import Stats from '../components/Stats.astro'
import EditionTimeline from '../components/EditionTimeline.astro'
import SpeakerCard from '../components/SpeakerCard.astro'
import { site } from '../data/site'
import { pastEditions, editions } from '../data/editions'

const latest = pastEditions[0]
const featured = latest ? latest.speakers.slice(0, 6) : []
const totalSpeakers = editions.reduce((n, e) => n + e.speakers.length, 0)
const audience = latest ? latest.disciplines.slice(0, 5) : []
const institutions = [
  'Mayo Clinic',
  'World Health Organization',
  'Icahn School of Medicine at Mount Sinai',
  'Tehran University of Medical Sciences',
]
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">The MedAI Summit archive</p>
      <h1 class="hero-title">
        Where <em>AI</em> meets medicine, kept on the record.
      </h1>
      <p class="lede hero-lede">
        MedAI Summit is a yearly summit on artificial intelligence in medicine. This site is its
        public archive. Every edition, every speaker and every talk stays here, open to revisit or
        watch for the first time.
      </p>
      <div class="hero-cta">
        <a href="/editions" class="btn btn-primary">
          Browse editions
          <svg class="arrow" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </a>
        <a href={site.channel} class="btn btn-ghost" target="_blank" rel="noopener">Follow on Telegram</a>
      </div>

      <div class="cred">
        <span class="cred-label">Past speakers came from</span>
        <ul class="cred-list">
          {institutions.map((i) => <li>{i}</li>)}
        </ul>
      </div>

      <dl class="ticker">
        <div><dt>Editions</dt><dd>{pastEditions.length}</dd></div>
        <div><dt>Speakers</dt><dd>{totalSpeakers}</dd></div>
        <div><dt>Since</dt><dd>{editions[editions.length - 1]?.year}</dd></div>
      </dl>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-glow-2" aria-hidden="true"></div>
  </section>

  {
    latest && (
      <section class="section">
        <div class="container">
          <div class="reveal">
            <SectionHeading index="01" eyebrow={`First edition, ${latest.year}`} title="What the first edition looked like" lede="One edition in, held online across two days in October 2025. These are the figures that actually showed up." />
          </div>
          <div class="reveal numbers">
            <Stats stats={latest.stats} />
          </div>
        </div>
      </section>
    )
  }

  <!-- Timeline -->
  <section class="section band">
    <div class="container">
      <div class="reveal">
        <SectionHeading index="02" eyebrow="The archive" title="Every edition, year by year" lede="One entry per year, starting with 2025. Open a year to see its speakers, its talks and who came." />
      </div>
      <div class="tl-wrap">
        <EditionTimeline editions={pastEditions} showUpcoming />
      </div>
    </div>
  </section>

  {
    latest && featured.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="reveal head-row">
            <SectionHeading index="03" eyebrow={`From the ${latest.year} program`} title="A few of the talks" />
            <a href={`/editions/${latest.slug}`} class="see-all">
              See all {latest.speakers.length}
              <svg class="arrow" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </a>
          </div>
          <div class="grid reveal">
            {featured.map((s) => <SpeakerCard speaker={s} />)}
          </div>
        </div>
      </section>
    )
  }

  <!-- For invited speakers -->
  {
    latest && (
      <section class="section band">
        <div class="container invite">
          <div class="reveal invite-copy">
            <p class="eyebrow">For invited speakers</p>
            <h2 class="invite-title">Say it once here, and it keeps working for you.</h2>
            <p class="invite-text">
              We invited you because your work belongs in this conversation, and the audience is the
              reason to give it your time. At the first edition, more than 500 people joined from
              Iran, Colombia, India and Tajikistan. Most were clinicians, alongside engineers,
              computer scientists, nurses, pharmacists and lab scientists. These are people who can
              act on what you present, not a general crowd.
            </p>
            <p class="invite-text">
              Your talk does not end when you stop sharing your screen. We record every session, add
              English subtitles, publish your handouts and keep it here on the archive. A talk given
              once in October keeps reaching clinicians who find it months later, with your name and
              affiliation on it. You bring the talk, and we handle the recording, the subtitles and
              the reach.
            </p>
            <a href={site.contact} class="btn btn-primary invite-cta" target="_blank" rel="noopener">
              Talk to the team on Telegram
              <svg class="arrow" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </a>
          </div>
          <aside class="reveal invite-card">
            <p class="invite-card-label">Who was in the room</p>
            <p class="invite-card-sub">First edition, by field</p>
            <ul class="aud">
              {audience.map((d) => (
                <li>
                  <span class="aud-name">{d.name}</span>
                  <span class="aud-count">{d.count}</span>
                </li>
              ))}
            </ul>
            <p class="invite-card-foot">More than 500 participants, from {latest.countries.length} countries.</p>
          </aside>
        </div>
      </section>
    )
  }

  <!-- Closing CTA -->
  <section class="section">
    <div class="container">
      <div class="cta reveal">
        <h2 class="cta-title">The recordings stay open.</h2>
        <p class="cta-text">Every session from every edition was recorded and subtitled in English, with handouts. Nothing is taken down after the event. Ask for access, or follow the channel for the next edition.</p>
        <div class="cta-actions">
          <a href={site.contact} class="btn btn-primary" target="_blank" rel="noopener">Ask for recordings</a>
          <a href={site.channel} class="btn btn-ghost" target="_blank" rel="noopener">Follow the summit</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 9vw, 7rem) clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero-glow {
    position: absolute;
    inset: auto -10% 30% 40%;
    height: 520px;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--pine) 26%, transparent), transparent 70%);
    filter: blur(16px);
    pointer-events: none;
    z-index: -1;
  }
  .hero-glow-2 {
    position: absolute;
    inset: 6% 52% auto -8%;
    height: 340px;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--amber) 14%, transparent), transparent 70%);
    filter: blur(26px);
    pointer-events: none;
    z-index: -1;
  }
  .hero-title {
    margin-top: 1.3rem;
    font-size: clamp(2.4rem, 6.6vw, 4.6rem);
    max-width: 19ch;
  }
  .hero-title em {
    font-style: italic;
    color: var(--pine);
  }
  .hero-lede {
    margin-top: 1.5rem;
    max-width: 54ch;
    font-size: clamp(1.1rem, 2.3vw, 1.35rem);
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }
  .cred {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 2.6rem;
  }
  .cred-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .cred-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .cred-list li {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-soft);
    padding: 0.35rem 0.8rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: color-mix(in srgb, var(--card) 55%, transparent);
  }
  .ticker {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin-top: 2.6rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
  .ticker dt {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .ticker dd {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 5vw, 2.3rem);
    font-weight: 560;
    color: var(--ink);
    margin-top: 0.2rem;
  }
  .band {
    background: var(--paper-2);
    border-block: 1px solid var(--line);
  }
  .numbers,
  .tl-wrap {
    margin-top: 2.5rem;
  }
  .head-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: flex-end;
    justify-content: space-between;
  }
  .see-all {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 650;
    font-size: 0.92rem;
    color: var(--pine);
  }
  .see-all:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .see-all:hover .arrow {
    transform: translateX(3px);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
    margin-top: 2.5rem;
  }

  /* For invited speakers */
  .invite {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .invite-title {
    margin-top: 1.1rem;
    font-size: clamp(1.8rem, 4.5vw, 2.9rem);
    max-width: 20ch;
  }
  .invite-text {
    margin-top: 1.2rem;
    max-width: 62ch;
    color: var(--ink-soft);
    line-height: 1.75;
  }
  .invite-cta {
    margin-top: 1.8rem;
  }
  .invite-card {
    padding: 1.7rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }
  .invite-card-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--pine);
  }
  .invite-card-sub {
    margin-top: 0.25rem;
    font-size: 0.9rem;
    color: var(--ink-faint);
  }
  .aud {
    list-style: none;
    padding: 0;
    margin-top: 1.3rem;
  }
  .aud li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--line);
  }
  .aud-name {
    font-weight: 600;
    color: var(--ink);
  }
  .aud-count {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 560;
    color: var(--amber);
  }
  .invite-card-foot {
    margin-top: 1.2rem;
    font-size: 0.92rem;
    color: var(--ink-soft);
  }

  .cta {
    text-align: center;
    max-width: 46ch;
    margin-inline: auto;
    padding: clamp(2.5rem, 6vw, 4rem) 1.5rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }
  .cta-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    max-width: 18ch;
    margin-inline: auto;
  }
  .cta-text {
    margin-top: 1rem;
    color: var(--ink-soft);
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: center;
    margin-top: 1.8rem;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .invite {
      grid-template-columns: 1.5fr 1fr;
      gap: 4rem;
    }
  }
  @media (min-width: 980px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

---
import Base from '../layouts/Base.astro'
import SectionHeading from '../components/SectionHeading.astro'
import Stats from '../components/Stats.astro'
import EditionTimeline from '../components/EditionTimeline.astro'
import SpeakerCard from '../components/SpeakerCard.astro'
import { site } from '../data/site'
import { pastEditions, editions } from '../data/editions'

const latest = pastEditions[0]
const featured = latest ? latest.speakers.slice(0, 6) : []
const totalSpeakers = editions.reduce((n, e) => n + e.speakers.length, 0)
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Artificial intelligence in medicine</p>
      <h1 class="hero-title">
        A yearly record of where <em>AI</em> meets medicine.
      </h1>
      <p class="lede hero-lede">
        MedAI Summit gathers researchers, clinicians and engineers each year. This site keeps the
        record: every edition, its speakers and its talks, open for anyone to revisit.
      </p>
      <div class="hero-cta">
        <a href="/editions" class="btn btn-primary">
          Browse editions
          <svg class="arrow" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </a>
        <a href={site.channel} class="btn btn-ghost" target="_blank" rel="noopener">Follow on Telegram</a>
      </div>

      <dl class="ticker">
        <div><dt>Editions</dt><dd>{pastEditions.length}</dd></div>
        <div><dt>Speakers</dt><dd>{totalSpeakers}</dd></div>
        <div><dt>Since</dt><dd>{editions[editions.length - 1]?.year}</dd></div>
      </dl>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  {
    latest && (
      <section class="section">
        <div class="container">
          <div class="reveal">
            <SectionHeading index="01" eyebrow={`First edition, ${latest.year}`} title="By the numbers" lede="A snapshot of the most recent summit. Each edition adds its own record to the archive." />
          </div>
          <div class="reveal numbers">
            <Stats stats={latest.stats} />
          </div>
        </div>
      </section>
    )
  }

  <!-- Timeline -->
  <section class="section band">
    <div class="container">
      <div class="reveal">
        <SectionHeading index="02" eyebrow="The archive" title="Every edition, year by year" lede="The summit grows one year at a time. New editions join the top of the timeline." />
      </div>
      <div class="tl-wrap">
        <EditionTimeline editions={pastEditions} showUpcoming />
      </div>
    </div>
  </section>

  {
    latest && featured.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="reveal head-row">
            <SectionHeading index="03" eyebrow={`Talks from ${latest.year}`} title="A few of the talks" />
            <a href={`/editions/${latest.slug}`} class="see-all">
              See all {latest.speakers.length}
              <svg class="arrow" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </a>
          </div>
          <div class="grid reveal">
            {featured.map((s) => <SpeakerCard speaker={s} />)}
          </div>
        </div>
      </section>
    )
  }

  <!-- Closing CTA -->
  <section class="section">
    <div class="container">
      <div class="cta reveal">
        <h2 class="cta-title">Recordings, slides and handouts stay open.</h2>
        <p class="cta-text">Every session is kept for anyone who joins later. Message the team to get access, or follow the channel for the next edition.</p>
        <div class="cta-actions">
          <a href={site.contact} class="btn btn-primary" target="_blank" rel="noopener">Ask for recordings</a>
          <a href={site.channel} class="btn btn-ghost" target="_blank" rel="noopener">Follow the summit</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 9vw, 7rem) clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero-glow {
    position: absolute;
    inset: auto -10% 30% 40%;
    height: 520px;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--pine) 22%, transparent), transparent 70%);
    filter: blur(20px);
    pointer-events: none;
    z-index: -1;
  }
  .hero-title {
    margin-top: 1.3rem;
    font-size: clamp(2.5rem, 8vw, 5.2rem);
    max-width: 15ch;
  }
  .hero-title em {
    font-style: italic;
    color: var(--pine);
  }
  .hero-lede {
    margin-top: 1.5rem;
    max-width: 52ch;
    font-size: clamp(1.1rem, 2.3vw, 1.35rem);
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }
  .ticker {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
  .ticker dt {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .ticker dd {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 560;
    color: var(--ink);
    margin-top: 0.2rem;
  }
  .band {
    background: var(--paper-2);
    border-block: 1px solid var(--line);
  }
  .numbers,
  .tl-wrap {
    margin-top: 2.5rem;
  }
  .head-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: flex-end;
    justify-content: space-between;
  }
  .see-all {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 650;
    font-size: 0.92rem;
    color: var(--pine);
  }
  .see-all:hover .arrow {
    transform: translateX(3px);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
    margin-top: 2.5rem;
  }
  .cta {
    text-align: center;
    max-width: 44ch;
    margin-inline: auto;
    padding: clamp(2.5rem, 6vw, 4rem) 1.5rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }
  .cta-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    max-width: 18ch;
    margin-inline: auto;
  }
  .cta-text {
    margin-top: 1rem;
    color: var(--ink-soft);
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: center;
    margin-top: 1.8rem;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 980px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

---
import type { Discipline } from '../data/editions'
interface Props {
  disciplines: Discipline[]
}
const { disciplines } = Astro.props
const max = Math.max(1, ...disciplines.map((d) => d.count))
---

<ul class="bars">
  {
    disciplines.map((d) => (
      <li class="bar">
        <div class="bar-top">
          <span class="bar-name">{d.name}</span>
          <span class="bar-count">{d.count}</span>
        </div>
        <div class="track">
          <div class="fill" style={`width:${Math.max(4, Math.round((d.count / max) * 100))}%`} />
        </div>
      </li>
    ))
  }
</ul>

<style>
  .bars {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
  }
  .bar-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }
  .bar-name {
    font-weight: 600;
    font-size: 0.96rem;
  }
  .bar-count {
    font-family: var(--font-display);
    font-weight: 560;
    color: var(--ink-soft);
    font-variant-numeric: tabular-nums;
  }
  .track {
    height: 8px;
    border-radius: 999px;
    background: var(--paper-2);
    overflow: hidden;
    border: 1px solid var(--line);
  }
  .fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--pine-deep), var(--pine));
  }
  [dir='rtl'] .fill {
    background: linear-gradient(270deg, var(--pine-deep), var(--pine));
  }
</style>

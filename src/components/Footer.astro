---
import { site } from '../data/site'
import BrandMark from './BrandMark.astro'
const year = new Date().getFullYear()
---

<footer class="site-footer">
  <div class="container">
    <div class="top">
      <div class="brand-col">
        <a href="/" class="brand" aria-label={site.name}>
          <BrandMark size={32} />
          <span>MedAI <em>Summit</em></span>
        </a>
        <p class="blurb">{site.tagline} An open archive of every edition, its speakers and its talks.</p>
      </div>

      <nav class="col" aria-label="Explore">
        <h2>Explore</h2>
        <a href="/">Home</a>
        <a href="/editions">Editions</a>
        <a href="/about">About</a>
      </nav>

      <nav class="col" aria-label="Connect">
        <h2>Connect</h2>
        {site.socials.map((s) => <a href={s.url} target="_blank" rel="noopener">{s.label}</a>)}
      </nav>
    </div>

    <hr class="rule" />

    <div class="bottom">
      <p>© {year} {site.name}. Archive of past editions.</p>
      <p><a href={site.contact} target="_blank" rel="noopener">Ask the team for recordings</a></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    background: var(--paper-2);
    border-top: 1px solid var(--line);
    padding-block: clamp(2.5rem, 5vw, 4rem) 2rem;
  }
  .top {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 560;
  }
  .brand em {
    font-style: italic;
    color: var(--pine);
  }
  .blurb {
    margin-top: 1rem;
    max-width: 40ch;
    color: var(--ink-soft);
    font-size: 0.96rem;
  }
  .col h2 {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.9rem;
  }
  .col a {
    display: block;
    padding: 0.28rem 0;
    color: var(--ink-soft);
    font-weight: 550;
    transition: color 0.15s ease;
  }
  .col a:hover {
    color: var(--pine);
  }
  .rule {
    margin-block: 2.2rem 1.4rem;
  }
  .bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.5rem;
    justify-content: space-between;
    align-items: center;
    color: var(--ink-faint);
    font-size: 0.88rem;
  }
  .bottom a {
    color: var(--ink-soft);
  }
  .bottom a:hover {
    color: var(--pine);
  }

  @media (min-width: 720px) {
    .top {
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 3rem;
    }
  }
</style>

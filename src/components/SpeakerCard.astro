---
import type { Speaker } from '../data/editions'
interface Props {
  speaker: Speaker
}
const { speaker } = Astro.props
const Tag = speaker.url ? 'a' : 'div'
const linkAttrs = speaker.url ? { href: speaker.url, target: '_blank', rel: 'noopener' } : {}
---

<Tag class:list={['sp', speaker.url && 'is-link']} {...linkAttrs}>
  <div class="sp-head">
    <div class="sp-names">
      <p class="sp-name">{speaker.name}</p>
      {speaker.nameFa && <p class="sp-name-fa" dir="rtl">{speaker.nameFa}</p>}
    </div>
    <span class="chip">{speaker.affiliation}</span>
  </div>
  <p class="sp-talk">{speaker.talk}</p>
  {speaker.talkFa && <p class="sp-talk-fa" dir="rtl">{speaker.talkFa}</p>}
  {
    speaker.url && (
      <span class="sp-watch">
        Watch the recording
        <svg class="arrow" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </span>
    )
  }
</Tag>

<style>
  .sp {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    height: 100%;
    padding: 1.35rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .is-link:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--pine) 45%, var(--line));
    box-shadow: var(--shadow);
  }
  .sp-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .sp-name {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 560;
    line-height: 1.2;
  }
  .sp-name-fa {
    margin-top: 0.15rem;
    font-size: 0.9rem;
    color: var(--ink-faint);
  }
  .chip {
    flex-shrink: 0;
  }
  .sp-talk {
    font-size: 0.98rem;
    color: var(--ink-soft);
    line-height: 1.5;
    padding-left: 0.8rem;
    border-left: 2px solid var(--amber-soft);
  }
  .is-link:hover .sp-talk {
    border-left-color: var(--amber);
  }
  .sp-talk-fa {
    font-size: 0.92rem;
    color: var(--ink-faint);
    line-height: 1.7;
  }
  .sp-watch {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.4rem;
    font-size: 0.82rem;
    font-weight: 650;
    color: var(--pine);
  }
  .is-link:hover .sp-watch .arrow {
    transform: translateX(3px);
  }
</style>
